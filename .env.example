# Database
# Connect your PostgreSQL instance
DATABASE_URL="postgresql://user:password@localhost:5432/trado_db"

# NextAuth (Google OAuth)
# Get credentials from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"

# A random string for session encryption. Generate with 'openssl rand -base64 32'
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Cloudinary (Media Hosting)
# Sign up at https://cloudinary.com/
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="your-upload-preset"

# Real-time Engine
NEXT_PUBLIC_SOCKET_SERVER_URL="http://localhost:3000"

# Copy to .env and fill in values:  cp .env.example .env

# -----------------------------------------------------------------------------
# MongoDB — Prisma requires a replica set name in the URI when using transactions
# -----------------------------------------------------------------------------
# Local (after rs.initiate(), replSetName rs0):
DATABASE_URL="mongodb://localhost:27017/trado?replicaSet=rs0"

# MongoDB Atlas (use your cluster connection string; ensure replica set compatible):
# DATABASE_URL="mongodb+srv://USER:PASS@cluster.mongodb.net/trado?retryWrites=true&w=majority"

# -----------------------------------------------------------------------------
# NextAuth — app uses email + password (@iitgn.ac.in only), not OAuth
# -----------------------------------------------------------------------------
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3001"

# -----------------------------------------------------------------------------
# Cloudinary (optional for local dev; listing photos use Next Cloudinary widget)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=""
# CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"

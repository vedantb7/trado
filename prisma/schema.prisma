datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Hostel {
  Aiyana
  Beauki
  Chimair
  Duari
  Ekaant
  Falgun
  Gagan
  Hridaya
  Indu
  Jasubai
}

enum Category {
  Electronics
  Books
  Cycles
  HostelGear
}

enum ListingStatus {
  Available
  Reserved
  Sold
}

enum OfferStatus {
  Proposed
  Countered
  Accepted
  Declined
  Completed
}

enum UserRole {
  Buyer
  Seller
  Admin
}

enum FlagStatus {
  Pending
  Reviewed
  Resolved
  Dismissed
}

model User {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  name            String?
  email           String    @unique
  emailVerified   DateTime?
  password        String?
  avatar          String?
  bio             String?
  karmaScore      Float     @default(0)
  hostel          Hostel?
  wing            String?
  contactPref     Json?
  roles           UserRole[] @default([Buyer])
  isSuspended     Boolean   @default(false)
  suspensionReason String?
  
  accounts        Account[]
  sessions        Session[]
  
  listings        Listing[] @relation("SellerListings")
  offers          Offer[]   @relation("BuyerOffers")
  
  sentMessages    Message[] @relation("SentMessages")
  reviewsGiven    Review[]  @relation("ReviewerReviews")
  reviewsReceived Review[]  @relation("RevieweeReviews")
  
  bookmarks       Bookmark[]
  flagsReported   Flag[]    @relation("FlagReporter")
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Listing {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  sellerId       String        @db.ObjectId
  seller         User          @relation("SellerListings", fields: [sellerId], references: [id], onDelete: Cascade)
  
  title          String
  description    String
  category       Category
  price          Float
  images         String[]
  tags           String[]
  status         ListingStatus @default(Available)
  isUrgent       Boolean       @default(false)
  locationHostel Hostel?
  
  offers         Offer[]
  bookmarks      Bookmark[]
  
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Offer {
  id           String      @id @default(auto()) @map("_id") @db.ObjectId
  buyerId      String      @db.ObjectId
  buyer        User        @relation("BuyerOffers", fields: [buyerId], references: [id], onDelete: Cascade)
  
  listingId    String      @db.ObjectId
  listing      Listing     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  
  priceOffered  Float
  status        OfferStatus @default(Proposed)
  handshakeCode String?
  
  room          ChatRoom?
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model ChatRoom {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  offerId      String    @unique @db.ObjectId
  offer        Offer     @relation(fields: [offerId], references: [id], onDelete: Cascade)
  
  messages     Message[]
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Message {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  roomId     String   @db.ObjectId
  room       ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  
  senderId   String   @db.ObjectId
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  
  content    String
  timestamp  DateTime @default(now())
}

model Review {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  offerId    String   @db.ObjectId
  reviewerId String   @db.ObjectId
  reviewee   String   @db.ObjectId
  
  reviewer   User     @relation("ReviewerReviews", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewedUser User   @relation("RevieweeReviews", fields: [reviewee], references: [id], onDelete: Cascade)
  
  rating     Int
  comment    String?
  
  createdAt  DateTime @default(now())
  
  @@unique([offerId, reviewerId])
}

model Bookmark {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  listingId String   @db.ObjectId
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@unique([userId, listingId])
}

model Flag {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  type         String
  targetId     String
  reporterId   String    @db.ObjectId
  reporter     User      @relation("FlagReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  
  reason       String
  description  String?
  status       FlagStatus @default(Pending)
  resolution   String?
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
